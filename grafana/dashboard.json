          "rawSql": "SELECT w.start_date AS \"开始时间\", w.end_date AS \"结束时间\", CASE w.workout_activity_type WHEN 'HKWorkoutActivityTypeRunning' THEN '🏃 跑步' WHEN 'HKWorkoutActivityTypeWalking' THEN '🚶 步行' WHEN 'HKWorkoutActivityTypeCycling' THEN '🚴 骑行' WHEN 'HKWorkoutActivityTypeSwimming' THEN '🏊 游泳' WHEN 'HKWorkoutActivityTypeYoga' THEN '🧘 瑜伽' WHEN 'HKWorkoutActivityTypeTraditionalStrengthTraining' THEN '🏋️ 力量训练' WHEN 'HKWorkoutActivityTypeFunctionalStrengthTraining' THEN '💪 功能性力量训练' WHEN 'HKWorkoutActivityTypeElliptical' THEN '椭圆机' WHEN 'HKWorkoutActivityTypeRowing' THEN '🚣 划船' WHEN 'HKWorkoutActivityTypeStairs' THEN '🪜 爬楼梯' WHEN 'HKWorkoutActivityTypeHiking' THEN '🥾 徒步' WHEN 'HKWorkoutActivityTypeDance' THEN '💃 舞蹈' WHEN 'HKWorkoutActivityTypeJumpRope' THEN '🪢 跳绳' WHEN 'HKWorkoutActivityTypeCoreTraining' THEN '核心训练' WHEN 'HKWorkoutActivityTypeFlexibility' THEN '柔韧性训练' WHEN 'HKWorkoutActivityTypeHighIntensityIntervalTraining' THEN '⚡ 高强度间歇训练' WHEN 'HKWorkoutActivityTypeMixedCardio' THEN '❤️ 混合有氧' WHEN 'HKWorkoutActivityTypeCardioDance' THEN '💃 有氧舞蹈' WHEN 'HKWorkoutActivityTypeStairClimbing' THEN '🪜 爬楼梯' WHEN 'HKWorkoutActivityTypeDownhillSkiing' THEN '⛷️ 高山滑雪' WHEN 'HKWorkoutActivityTypeSnowboarding' THEN '🏂 单板滑雪' WHEN 'HKWorkoutActivityTypeCrossCountrySkiing' THEN '🎿 越野滑雪' WHEN 'HKWorkoutActivityTypeSurfingSports' THEN '🏄 冲浪' WHEN 'HKWorkoutActivityTypePaddleSports' THEN '🛶 划桨运动' WHEN 'HKWorkoutActivityTypeSkatingSports' THEN '⛸️ 滑冰' WHEN 'HKWorkoutActivityTypeBowling' THEN '🎳 保龄球' WHEN 'HKWorkoutActivityTypeGolf' THEN '⛳ 高尔夫' WHEN 'HKWorkoutActivityTypeTennis' THEN '🎾 网球' WHEN 'HKWorkoutActivityTypeBadminton' THEN '🏸 羽毛球' WHEN 'HKWorkoutActivityTypeTableTennis' THEN '🏓 乒乓球' WHEN 'HKWorkoutActivityTypeBasketball' THEN '🏀 篮球' WHEN 'HKWorkoutActivityTypeSoccer' THEN '⚽ 足球' WHEN 'HKWorkoutActivityTypeVolleyball' THEN '🏐 排球' WHEN 'HKWorkoutActivityTypeBaseball' THEN '⚾ 棒球' WHEN 'HKWorkoutActivityTypeSoftball' THEN '🥎 垒球' WHEN 'HKWorkoutActivityTypeHandCycling' THEN '🚴 手摇车' WHEN 'HKWorkoutActivityTypeMindAndBody' THEN '🧘 身心运动' WHEN 'HKWorkoutActivityTypeBarre' THEN '芭杆' WHEN 'HKWorkoutActivityTypePilates' THEN '普拉提' ELSE w.workout_activity_type END AS \"锻炼类型\", ROUND(COALESCE(NULLIF(w.duration, 0), EXTRACT(EPOCH FROM (w.end_date - w.start_date))/60)::numeric, 1) AS \"时长(分钟)\", ROUND(COALESCE(NULLIF(w.total_distance, 0), (SELECT SUM(hr.value) FROM health_records hr WHERE hr.type IN ('DistanceWalkingRunning', 'DistanceCycling', 'DistanceSwimming') AND hr.start_date >= w.start_date AND hr.end_date <= w.end_date))::numeric, 2) AS \"距离(km)\", ROUND(COALESCE(NULLIF(w.total_energy_burned, 0), (SELECT SUM(hr.value) FROM health_records hr WHERE hr.type = 'ActiveEnergyBurned' AND hr.start_date >= w.start_date AND hr.end_date <= w.end_date))::numeric, 1) AS \"消耗(千卡)\" FROM workouts w WHERE w.start_date >= $__timeFrom() AND w.start_date <= $__timeTo() ORDER BY w.start_date DESC",
