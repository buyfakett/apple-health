      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "${ds}"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH daily AS (SELECT DATE(start_date) as day, SUM(CASE WHEN source_name LIKE '%Watch%' THEN value ELSE 0 END) as watch_steps, SUM(CASE WHEN source_name LIKE '%iPhone%' THEN value ELSE 0 END) as iphone_steps, SUM(CASE WHEN source_name LIKE '%小米%' THEN value ELSE 0 END) as xiaomi_steps FROM health_records WHERE type = 'StepCount' AND start_date >= $__timeFrom() AND start_date <= $__timeTo() GROUP BY DATE(start_date)) SELECT day as time, CASE WHEN watch_steps > 0 THEN watch_steps WHEN iphone_steps > 0 THEN iphone_steps ELSE xiaomi_steps END as \"每日步数\" FROM daily ORDER BY time",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
      "title": "步数统计",
      "type": "timeseries"
    },
